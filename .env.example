# Environment variables for the Academic Assessment Platform

# Supabase Configuration
# Replace with your Supabase Project settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Database Connection (PostgreSQL connection for migrations/direct DB access)
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# Security Settings
# Generate a secure secret key for JWT (e.g., using: openssl rand -hex 32)
JWT_SECRET_KEY=generate_a_secure_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App Settings
ENVIRONMENT=development
LOG_LEVEL=info

# Frontend Settings (Only if used in build time)
VITE_API_URL=http://localhost:8000
